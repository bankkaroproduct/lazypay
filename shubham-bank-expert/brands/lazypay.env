# LAZYPAY Brand Configuration

NEXT_PUBLIC_BRAND_NAME=LAZYPAY
NEXT_PUBLIC_BRAND_TAGLINE=Smart Payment Solutions for Everyone
NEXT_PUBLIC_BRAND_LOGO=/lazypay-logo.png
NEXT_PUBLIC_BRAND_FAVICON=/lazypay-favicon.png
NEXT_PUBLIC_BRAND_EMAIL=support@lazypay.com

# Primary Color - Pink/Magenta (matching LAZYPAY logo)
# HUE: 330 (Pink/Magenta), Saturation: 100%, Lightness: 45%
NEXT_PUBLIC_PRIMARY_HUE=330
NEXT_PUBLIC_PRIMARY_SAT=100%
NEXT_PUBLIC_PRIMARY_LIGHT=45%

# Secondary Color - Light Gray
NEXT_PUBLIC_SECONDARY_HUE=0
NEXT_PUBLIC_SECONDARY_SAT=0%
NEXT_PUBLIC_SECONDARY_LIGHT=96.1%

# Header Background Color
NEXT_PUBLIC_HEADER_BG_COLOR=#FF1E7E

# ============================================
# PARTNER API (CRITICAL FOR ATTRIBUTION)
# ============================================
# Each partner MUST have unique API key for revenue tracking
PARTNER_API_KEY=your_lazypay_api_key_here
PARTNER_TOKEN_URL=https://platform.lazypay.com/partner/token
PARTNER_BASE_URL=https://platform.lazypay.com/partner
NEXT_PUBLIC_APP_URL=https://lazypay.com

# Analytics (optional - add your GA measurement ID)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
